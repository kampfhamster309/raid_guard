# Copy this file to .env and fill in the values before running docker compose.

# ── Unraid server ────────────────────────────────────────────────────────────
# Used by: make push / make deploy
UNRAID_HOST=192.168.1.x

# ── Fritzbox (capture-agent) ─────────────────────────────────────────────────
FRITZ_HOST=192.168.178.1
FRITZ_USER=
FRITZ_PASSWORD=
# Interface to capture from. Find yours at http://192.168.178.1/html/capture.html
FRITZ_IFACE_ID=3-17

# ── Database (TimescaleDB) ───────────────────────────────────────────────────
DB_USER=raidguard
DB_PASSWORD=changeme
DB_NAME=raidguard

# ── Service ports (host-side) ────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Backend authentication ───────────────────────────────────────────────────
# Leave ADMIN_PASSWORD empty to disable login entirely (safe default for setup).
# Generate JWT_SECRET with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Without JWT_SECRET, tokens are invalidated on every restart.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# ── LM Studio ────────────────────────────────────────────────────────────────
LM_STUDIO_URL=http://192.168.1.x:1234/v1
LM_STUDIO_MODEL=gemma-4-27b
LM_ENRICHMENT_TIMEOUT=90
LM_MAX_TOKENS=512

# ── Pi-hole v6 ───────────────────────────────────────────────────────────────
PIHOLE_HOST=http://192.168.1.x
PIHOLE_PASSWORD=

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys once with:
#   cd services/backend && .venv/bin/python3 - << 'EOF'
#   from py_vapid import Vapid; import base64
#   from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat
#   v = Vapid(); v.generate_keys()
#   priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
#   pub  = v.public_key.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)
#   print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv).rstrip(b'=').decode())
#   print('VAPID_PUBLIC_KEY='  + base64.urlsafe_b64encode(pub).rstrip(b'=').decode())
#   EOF
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# Must be a mailto: or https: URL identifying the push service contact.
VAPID_SUBJECT=mailto:admin@example.com

# ── Home Assistant ───────────────────────────────────────────────────────────
# Webhook created via Settings → Automations → Webhooks in HA
HA_WEBHOOK_URL=
# Base URL of the raid_guard frontend — used for deep links in push notifications
DASHBOARD_URL=http://192.168.1.x:3000
